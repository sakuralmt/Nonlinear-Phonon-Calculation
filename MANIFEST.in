include README.md
include README_zh.md
include start_release.py
include install.sh
include tui
include npc
recursive-include nonlinear_phonon_calculation *
recursive-include qe_phonon_stage1_server_bundle *.py *.json *.csv *.md *.inp *.UPF
recursive-include server_highthroughput_workflow *.py *.json *.md *.sh
recursive-include mlff_modepair_workflow *.py *.json *.csv *.md *.dat *.png
recursive-include qe_modepair_handoff_workflow *.py *.json *.csv *.md
recursive-include examples *.md *.json *.csv *.inp *.UPF *.cif
prune .github
prune build
prune dist
prune n7
prune examples/wse2
prune nonlocal phonon
prune nonlinear_phonon_calculation.egg-info
prune mlff_modepair_workflow/native_dualtrack_runs
prune mlff_modepair_workflow/runs
prune qe_phonon_stage1_server_bundle/inputs
prune qe_phonon_stage1_server_bundle/qe_phonon_pes_run
prune qe_phonon_stage1_server_bundle/validated_remote
prune qe_modepair_handoff_workflow/exports
prune nonlinear_phonon_calculation/resources/n7
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude .DS_Store
global-exclude ._*
